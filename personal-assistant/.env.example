# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Anthropic (Claude) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google OAuth (Gmail + Google Calendar) ───────────────
# Create credentials at https://console.cloud.google.com
# Scopes needed: gmail.readonly, gmail.compose, gmail.send, calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── NextAuth ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── GoHighLevel ──────────────────────────────────────────
# Get from GHL Settings → Integrations → API Keys
GHL_API_KEY=
GHL_LOCATION_ID=

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=file:./dev.db

# ─── App Config ───────────────────────────────────────────
# Your name — used in assistant prompts
ASSISTANT_OWNER_NAME=
