generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  image        String?
  passwordHash String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projects  Project[]
  accounts  Account[]
  sessions  Session[]
}

// NextAuth adapter tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      ProjectStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  clips        Clip[]
  roughCuts    RoughCut[]
  chatMessages ChatMessage[]
  exports      Export[]
}

enum ProjectStatus {
  DRAFT
  PROCESSING
  READY
  ERROR
}

model Clip {
  id              String     @id @default(cuid())
  projectId       String
  project         Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileName        String
  s3Key           String     @unique
  s3AudioKey      String?
  durationSeconds Float?
  width           Int?
  height          Int?
  fps             Float?
  codec           String?
  role            ClipRole   @default(AROLL)
  status          ClipStatus @default(UPLOADED)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  transcript Transcript?
  brollTags  BrollTag[]
}

enum ClipRole {
  AROLL
  BROLL
}

enum ClipStatus {
  UPLOADED
  EXTRACTING_AUDIO
  TRANSCRIBING
  TRANSCRIBED
  ERROR
}

model Transcript {
  id        String   @id @default(cuid())
  clipId    String   @unique
  clip      Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
  // Full Whisper verbose_json response stored as JSONB
  // Shape: { text, segments: [{start, end, text}], words: [{word, start, end}] }
  rawJson   Json
  plainText String
  language  String?
  createdAt DateTime @default(now())
}

model BrollTag {
  id          String   @id @default(cuid())
  clipId      String
  clip        Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
  startSec    Float
  endSec      Float
  description String
  tags        String[]
  createdAt   DateTime @default(now())
}

model RoughCut {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version   Int      @default(1)
  prompt    String?
  // Array of RoughCutSegment: { clipId, clipFileName, startSec, endSec, text, order }
  segments  Json
  rationale String?
  createdAt DateTime @default(now())

  exports Export[]
}

model ChatMessage {
  id         String      @id @default(cuid())
  projectId  String
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role       MessageRole
  content    String
  roughCutId String?
  createdAt  DateTime    @default(now())
}

enum MessageRole {
  USER
  ASSISTANT
}

model Export {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roughCutId  String
  roughCut    RoughCut     @relation(fields: [roughCutId], references: [id])
  format      ExportFormat
  status      ExportStatus @default(PENDING)
  s3Key       String?
  downloadUrl String?
  errorMsg    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum ExportFormat {
  FCPXML
  EDL
}

enum ExportStatus {
  PENDING
  PROCESSING
  DONE
  ERROR
}
